{
  "setup": {
    "runtime_options": {
      "SUPABASE_URL": "https://test.supabase.co",
      "ALLOW_TABLE_VIEW": "true"
    }
  },
  "tests": [
    {
      "name": "getModel infers columns by sampling a row (no OpenAPI probe)",
      "method": "getModel",
      "arguments": {
        "context": {
          "queryMode": "view",
          "targetName": "products",
          "idColumn": "id"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/products?limit=1",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [
                {
                  "id": 1,
                  "name": "Bite Back Aged Cheddar 150g",
                  "base_price": 2.49,
                  "is_active": true,
                  "created_at": "2024-01-15T10:30:00Z"
                }
              ]
            }
          }
        ]
      }
    },
    {
      "name": "getPage view mode with filter and sort",
      "method": "getPage",
      "arguments": {
        "config": {
          "limit": 10,
          "filters": [{ "property": "brand_id", "value": "1", "type": "exact" }],
          "sorting": [{ "property": "name", "direction": "asc" }]
        },
        "context": {
          "queryMode": "view",
          "targetName": "products",
          "idColumn": "id",
          "columnsOverride": "[{\"name\":\"id\",\"type\":\"number\"},{\"name\":\"name\",\"type\":\"singleLine\"},{\"name\":\"base_price\",\"type\":\"number\"}]"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/products?limit=10&offset=0&brand_id=eq.1&order=name.asc",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [
                { "id": 1, "name": "Bite Back Aged Cheddar 150g", "base_price": 2.49 },
                { "id": 2, "name": "Bite Back Jalapeño 150g", "base_price": 2.49 }
              ]
            }
          }
        ]
      }
    },
    {
      "name": "getPage rpc mode posts JSON params",
      "method": "getPage",
      "arguments": {
        "config": {
          "limit": 5
        },
        "context": {
          "queryMode": "rpc",
          "targetName": "spring_campaign",
          "rpcParams": "{\"campaign_slug\":\"spring-fresh\"}",
          "columnsOverride": "[{\"name\":\"product\",\"type\":\"singleLine\"},{\"name\":\"effective_price\",\"type\":\"number\"}]"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/rpc/spring_campaign?limit=5&offset=0",
            "method": "POST",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [
                { "product": "Chill Cola Original 6x33cl", "effective_price": 4.99 }
              ]
            }
          }
        ]
      }
    },
    {
      "name": "getPage infers columns from the fetched page (no extra discovery request)",
      "method": "getPage",
      "arguments": {
        "config": {
          "limit": 5
        },
        "context": {
          "queryMode": "rpc",
          "targetName": "get_campaign_products",
          "rpcParams": "{\"campaign_slug\":\"spring-fresh\"}"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/rpc/get_campaign_products?limit=5&offset=0",
            "method": "POST",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [
                { "product": "Chill Cola Original 6x33cl", "effective_price": 4.99 }
              ]
            }
          }
        ]
      }
    },
    {
      "name": "getPageItemById applies configured filter alongside the id lookup",
      "method": "getPageItemById",
      "arguments": {
        "id": "NYB-COF-COL",
        "pageOptions": { "limit": 10 },
        "context": {
          "queryMode": "view",
          "targetName": "promo_products",
          "idColumn": "sku",
          "filter": "{\"campaign_slug\":\"spring-fresh\"}",
          "columnsOverride": "[{\"name\":\"sku\",\"type\":\"singleLine\"},{\"name\":\"Price\",\"type\":\"number\"}]"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/promo_products?limit=1&campaign_slug=eq.spring-fresh&sku=eq.NYB-COF-COL",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [{ "sku": "NYB-COF-COL", "Price": 4.99 }]
            }
          }
        ]
      }
    },
    {
      "name": "getPageItemById fetches single row by id",
      "method": "getPageItemById",
      "arguments": {
        "id": "5",
        "pageOptions": { "limit": 10 },
        "context": {
          "queryMode": "view",
          "targetName": "products",
          "idColumn": "id",
          "columnsOverride": "[{\"name\":\"id\",\"type\":\"number\"},{\"name\":\"name\",\"type\":\"singleLine\"}]"
        }
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://test.supabase.co/rest/v1/products?limit=1&id=eq.5",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": { "content-type": "application/json" },
              "body": [{ "id": 5, "name": "Chiara Ravioli 250g" }]
            }
          }
        ]
      }
    }
  ]
}
