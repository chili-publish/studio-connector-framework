{
  "setup": {
    "runtime_options": {
      "BASE_URL": "https://tenant.dam.aprimo.com/api/core"
    }
  },
  "tests": [
    {
      "name": "Query - default listing",
      "method": "query",
      "arguments": {
        "options": {
          "pageSize": 2,
          "pageToken": null,
          "filter": [],
          "collection": "/",
          "sortBy": null,
          "sortOrder": null
        },
        "context": {}
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://tenant.dam.aprimo.com/api/core/classifications?pageSize=2&page=1",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": {
                "content-type": "application/json"
              },
              "body": {
                "page": 1,
                "pageSize": 2,
                "totalCount": 2,
                "_embedded": {
                  "item": [
                    {
                      "id": "class-001",
                      "name": "Marketing Assets",
                      "hasChildren": true
                    },
                    {
                      "id": "class-002",
                      "name": "Product Images",
                      "hasChildren": false
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    },
    {
      "name": "Query - search with text filter",
      "method": "query",
      "arguments": {
        "options": {
          "pageSize": 10,
          "pageToken": null,
          "filter": ["banner"],
          "collection": "/",
          "sortBy": null,
          "sortOrder": null
        },
        "context": {}
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://tenant.dam.aprimo.com/api/core/search/records?pageSize=10&page=1",
            "method": "POST",
            "count": 1,
            "response": {
              "status": 200,
              "headers": {
                "content-type": "application/json"
              },
              "body": {
                "page": 1,
                "pageSize": 10,
                "totalCount": 1,
                "items": [
                  {
                    "id": "rec-100",
                    "title": "Homepage Banner",
                    "createdOn": "2025-01-15T10:00:00Z",
                    "modifiedOn": "2025-06-01T14:30:00Z",
                    "_embedded": {
                      "masterFileLatestVersion": {
                        "fileName": "banner.png",
                        "fileExtension": ".png",
                        "width": 1920,
                        "height": 600
                      }
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    },
    {
      "name": "Query - classification browsing",
      "method": "query",
      "arguments": {
        "options": {
          "pageSize": 10,
          "pageToken": null,
          "filter": [],
          "collection": "/class-001",
          "sortBy": null,
          "sortOrder": null
        },
        "context": {}
      },
      "asserts": {
        "fetch": [
          {
            "url": "https://tenant.dam.aprimo.com/api/core/classification/class-001",
            "method": "GET",
            "count": 1,
            "response": {
              "status": 200,
              "headers": {
                "content-type": "application/json"
              },
              "body": {
                "id": "class-001",
                "name": "Marketing Assets",
                "hasChildren": true,
                "_embedded": {
                  "children": {
                    "_embedded": {
                      "item": [
                        {
                          "id": "class-001a",
                          "name": "Banners",
